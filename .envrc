# direnv config — auto-enters the nix dev shell when you `cd` into the repo
# (provided you have direnv + nix-direnv installed).
#
# nix-direnv: https://github.com/nix-community/nix-direnv
#   NixOS: `programs.direnv.enable = true;` +
#          `programs.direnv.nix-direnv.enable = true;`
#   Other: `nix profile install nixpkgs#nix-direnv` and follow setup.
#
# First time: `direnv allow` from the repo root. This brings `dx`, the
# wasm-bindgen matching our dioxus fork, the wasm32 rust target, and the
# wasm C toolchain (clang) onto PATH so
# `dx serve --package web-editor --platform web` builds the browser editor.

if ! has nix_direnv_version || ! nix_direnv_version 3.0.4; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

use flake

# Re-evaluate when these change.
watch_file flake.nix flake.lock rust-toolchain.toml
